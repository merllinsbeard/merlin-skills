{
  "name": "merlin-skills",
  "version": "0.1.0",
  "private": false,
  "description": "A spec-first, skill-first, goal-first skill pack for autonomous web coding with Codex.",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/merllinsbeard/merlin-skills.git"
  },
  "bugs": {
    "url": "https://github.com/merllinsbeard/merlin-skills/issues"
  },
  "homepage": "https://github.com/merllinsbeard/merlin-skills#readme",
  "scripts": {
    "validate": "bash scripts/validate-layout.sh && node scripts/validate-manifest.mjs",
    "test": "npm run validate",
    "install:codex": "SKILL_ROOT=$HOME/.codex/skills bash scripts/install-local.sh",
    "install:claude": "SKILL_ROOT=$HOME/.claude/skills bash scripts/install-local.sh"
  },
  "keywords": [
    "codex",
    "skills",
    "spec-kit",
    "goal",
    "playwright",
    "agents"
  ],
  "engines": {
    "node": ">=20"
  }
}
